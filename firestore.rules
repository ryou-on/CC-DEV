rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // プレイリスト：誰でも読める・書き込みはローカルのみ許可
    match /playlists/{id} {
      allow read: if true;
      allow write: if request.auth != null ||
                      request.resource.data.keys().hasAny(['name','type','folderIds','videoIds','createdAt']);
    }

    // サムネイルメタ：誰でも読める
    match /video_meta/{id} {
      allow read: if true;
      allow write: if request.auth != null ||
                      request.resource.data.keys().hasAny(['thumbnailUrl']);
    }

    // Flight Strip TODO: ユーザー自身のデータのみ（tasks + meta 配下すべて）
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Flight Strip TODO Analytics: 認証ユーザーは読み書き可
    match /fst_analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // フィードバック: 認証ユーザーは書き込み可、読み取りは認証ユーザーのみ
    match /fst_feedback/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // フィードバック連番カウンター
    match /fst_feedback_meta/{docId} {
      allow read, write: if request.auth != null;
    }

    // App Dashboard: 読み書き許可
    match /apps/{id} {
      allow read, write: if true;
    }

    // ともえホーム: アプリリスト共有（認証不要）
    match /tomoe-home/{docId} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().hasOnly(['apps']) &&
        request.resource.data.apps is list &&
        request.resource.data.apps.size() <= 50;
    }

    // おうち巴寿司: 家族コードを知っている人同士で音声・画像を共有
    // ouchi-hamasushi/{familyCode}/assets/{assetKey}
    // assetKey は voice_otousan_まぐろ / image_avatar_okasan などの形式
    match /ouchi-hamasushi/{familyCode}/assets/{assetKey} {
      allow read: if true;
      // data URI 1件 <= 950KB、mimeType/size/updatedAt のみ受け付け
      allow create, update: if
        request.resource.data.keys().hasOnly(['data','mimeType','size','updatedAt']) &&
        request.resource.data.data is string &&
        request.resource.data.data.size() <= 950000;
      allow delete: if true;
    }

    // note-analytics: 個人分析ツール（パスワード不要・userId ベースのアクセス）
    match /note-analytics/{userId}/{document=**} {
      allow read, write: if true;
    }

    // COCO-ITTA: 家族でグループ共有（ログインユーザーのみ）
    // groupId はランダム6文字コードで共有。認証必須で読み書き許可
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    // BOMBING BAY: 匿名ランキング＆プレイログ（認証なし・作成のみ・改ざん不可）
    // bombing-bay/global/plays/{id}   … 1プレイ=1ドキュメント
    // bombing-bay/global/players/{pid} … 1端末=1ドキュメント（人数カウント用）
    match /bombing-bay/global/plays/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasOnly(['pid','name','map','score','destroyed','timeSec','result','startedAt','ua','endedAt']) &&
        request.resource.data.pid is string && request.resource.data.pid.size() <= 32 &&
        request.resource.data.name is string && request.resource.data.name.size() <= 10 &&
        request.resource.data.map is string && request.resource.data.map.size() <= 12 &&
        request.resource.data.score is number && request.resource.data.score >= 0 && request.resource.data.score < 1000000 &&
        request.resource.data.timeSec is number && request.resource.data.timeSec >= 0 && request.resource.data.timeSec < 36000 &&
        request.resource.data.result in ['clear', 'over'];
      allow update, delete: if false;
    }
    match /bombing-bay/global/players/{pid} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['createdAt', 'ua']);
      allow update, delete: if false;
    }

    // hihaho アナリティクス: プレイリスト表示・動画再生カウント（認証なし書き込み可）
    match /playlist_analytics/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /video_analytics/{uuid} {
      allow read: if true;
      allow write: if true;
    }

    // Meet Knowledge: チームコードを知っている人同士でQ&Aナレッジを共有
    // meet-knowledge/{teamCode}/entries/{entryId}
    match /meet-knowledge/{teamCode}/entries/{entryId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.keys().hasOnly(['question','answer','keywords','category','createdAt','updatedAt','hits','source']) &&
        request.resource.data.question is string && request.resource.data.question.size() <= 500 &&
        request.resource.data.answer is string && request.resource.data.answer.size() <= 5000 &&
        request.resource.data.keywords is list && request.resource.data.keywords.size() <= 20;
      allow delete: if true;
    }

    // その他は全拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // プレイリスト：誰でも読める・書き込みはローカルのみ許可
    match /playlists/{id} {
      allow read: if true;
      allow write: if request.auth != null ||
                      request.resource.data.keys().hasAny(['name','type','folderIds','videoIds','createdAt']);
    }

    // サムネイルメタ：誰でも読める
    match /video_meta/{id} {
      allow read: if true;
      allow write: if request.auth != null ||
                      request.resource.data.keys().hasAny(['thumbnailUrl']);
    }

    // Flight Strip TODO: ユーザー自身のデータのみ（tasks + meta 配下すべて）
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Flight Strip TODO Analytics: 認証ユーザーは読み書き可
    match /fst_analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // フィードバック: 認証ユーザーは書き込み可、読み取りは認証ユーザーのみ
    match /fst_feedback/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // フィードバック連番カウンター
    match /fst_feedback_meta/{docId} {
      allow read, write: if request.auth != null;
    }

    // App Dashboard: 読み書き許可
    match /apps/{id} {
      allow read, write: if true;
    }

    // おうち巴寿司: 家族コードを知っている人同士で音声・画像を共有
    // ouchi-hamasushi/{familyCode}/assets/{assetKey}
    // assetKey は voice_otousan_まぐろ / image_avatar_okasan などの形式
    match /ouchi-hamasushi/{familyCode}/assets/{assetKey} {
      allow read: if true;
      // data URI 1件 <= 950KB、mimeType/size/updatedAt のみ受け付け
      allow create, update: if
        request.resource.data.keys().hasOnly(['data','mimeType','size','updatedAt']) &&
        request.resource.data.data is string &&
        request.resource.data.data.size() <= 950000;
      allow delete: if true;
    }

    // note-analytics: 個人分析ツール（パスワード不要・userId ベースのアクセス）
    match /note-analytics/{userId}/{document=**} {
      allow read, write: if true;
    }

    // その他は全拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // プレイリスト：誰でも読める・書き込みはローカルのみ許可
    match /playlists/{id} {
      allow read: if true;
      allow write: if request.auth != null ||
                      request.resource.data.keys().hasAny(['name','type','folderIds','videoIds','createdAt']);
    }

    // サムネイルメタ：誰でも読める
    match /video_meta/{id} {
      allow read: if true;
      allow write: if request.auth != null ||
                      request.resource.data.keys().hasAny(['thumbnailUrl']);
    }

    // Flight Strip TODO: ユーザー自身のデータのみ（tasks + meta 配下すべて）
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Flight Strip TODO Analytics: 認証ユーザーは読み書き可
    match /fst_analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // フィードバック: 認証ユーザーは書き込み可、読み取りは認証ユーザーのみ
    match /fst_feedback/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // フィードバック連番カウンター
    match /fst_feedback_meta/{docId} {
      allow read, write: if request.auth != null;
    }

    // App Dashboard: 読み書き許可
    match /apps/{id} {
      allow read, write: if true;
    }

    // その他は全拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

{
  "manifest_version": 3,
  "name": "YT → hihaho Tab",
  "version": "0.6.0",
  "description": "YouTube動画の文字起こしから要約・用語集タブHTMLを生成してhihahoに自動配置するワークフロー自動化",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": { "service_worker": "background.js" },
  "sandbox": { "pages": ["preview.html"] },
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://api.anthropic.com/*",
    "https://api.github.com/*",
    "https://api.hihaho.com/*",
    "https://*.googlevideo.com/*",
    "https://api.openai.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT → hihaho Tab",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}

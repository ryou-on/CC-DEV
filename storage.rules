rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // COCO-ITTA: グループの写真はメンバー（認証済みユーザー）のみ読み書き可
    match /groups/{groupId}/pins/{pinId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // その他は全拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

{
  "manifest_version": 3,
  "name": "Kindle Auto Capturer v5.29.0 Ultimate",
  "version": "5.29.0",
  "description": "余白自動カット・重複削除・完了検知・タイトル/著者自動入力を備えたKindleキャプチャ拡張。",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "unlimitedStorage",
    "windows",
    "downloads"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://read.amazon.co.jp/*"
  ]
}
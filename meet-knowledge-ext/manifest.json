{
  "manifest_version": 3,
  "name": "Meet Knowledge サイドパネル",
  "version": "0.1.0",
  "description": "Google Meetの字幕から質問を検知し、社内ナレッジをサイドパネルに即時表示します",
  "permissions": ["sidePanel"],
  "host_permissions": ["https://meet.google.com/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Meet Knowledge を開く"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
